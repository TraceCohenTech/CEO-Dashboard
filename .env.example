# Google OAuth credentials (required)
# Create at: https://console.cloud.google.com/apis/credentials
# Scopes needed: Gmail (readonly), Calendar (readonly), Drive (readonly), Tasks (readonly)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token

# Dashboard password (required)
DASH_PASSWORD=your-password

# Footer links (optional)
NEXT_PUBLIC_TWITTER_URL=https://x.com/yourhandle
NEXT_PUBLIC_CONTACT_EMAIL=you@example.com

# ──────────────────────────────────────────────
# Phase 2: AI Features (optional)
# Without these, the dashboard works fully — AI features return mock/placeholder data
# ──────────────────────────────────────────────

# Anthropic API key for AI triage, drafts, and meeting briefs
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Model to use (optional, defaults to claude-sonnet-4-20250514)
# Options: claude-sonnet-4-20250514, claude-opus-4-20250514, claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ──────────────────────────────────────────────
# Phase 3: Database (optional)
# Without a database, triage results and drafts are stored in-memory
# and lost on restart. Add a database for persistent state.
# ──────────────────────────────────────────────

# Option A: Vercel Postgres
# POSTGRES_URL=postgres://...

# Option B: Turso (SQLite edge)
# TURSO_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-token

# Option C: Upstash Redis (for caching)
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=your-token
